{
	"name": "friendsoftypo3/content-blocks-gui",
	"type": "typo3-cms-extension",
	"description": "TYPO3 Content Blocks GUI.",
	"homepage": "https://typo3.org",
	"license": ["GPL-2.0-or-later"],
    "version": "0.1.2",
    "minimum-stability": "alpha",
	"authors": [{
		"name": "TYPO3 Content Types Team",
		"role": "Developer"
	}],
	"config": {
		"sort-packages": true
	},
	"require": {
		"typo3/cms-core": "^13.4.19",
        "friendsoftypo3/content-blocks": "^1.3.17"
	},
	"require-dev": {
		"phpunit/phpunit": "^11.0",
		"typo3/testing-framework": "^9.0"
	},
	"conflict": {
		"typo3/cms": "*"
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "content_blocks_gui"
		}
	},
	"autoload": {
		"psr-4": {
			"FriendsOfTYPO3\\ContentBlocksGui\\": "Classes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"FriendsOfTYPO3\\ContentBlocksGui\\Tests\\": "Tests/"
		}
	}
}
